{
  "name": "agentsmith",
  "version": "0.1.0",
  "description": "Canonical agent instructions and a generator that forges AGENTS.md for any project.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/agentsmith/require-explicit-model.mjs\""
          }
        ]
      }
    ]
  }
}
